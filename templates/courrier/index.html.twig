{% extends 'base.html.twig' %}

{% block title %}Trouver un courrier{% endblock %}

{% block body %}
    <div class="topbar page-band">
        <div>
            <h1>Trouver un courrier</h1>
            <p>Recherche multicritère par référence, date, interlocuteur, statut, imputation et contenu.</p>
        </div>
        <div class="actions">
            <a class="button secondary export-button" href="{{ path('app_courrier_export', filters|merge({format: 'excel'})) }}" title="Exporter la liste filtree vers Excel">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <path d="M14 2v6h6"/>
                    <path d="M8 13h8"/>
                    <path d="M8 17h8"/>
                </svg>
                Excel
            </a>
            <a class="button secondary export-button" href="{{ path('app_courrier_export', filters|merge({format: 'pdf'})) }}" title="Exporter la liste filtree en PDF">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <path d="M14 2v6h6"/>
                    <path d="M9 15h6"/>
                    <path d="M9 18h4"/>
                </svg>
                PDF
            </a>
            {% if is_granted('ROLE_COURRIER_EDIT') %}
                <a class="button" href="{{ path('app_courrier_new') }}">Enregistrer un courrier</a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                {% if isPendingDeletionView %}
                    <a class="button secondary" href="{{ path('app_courrier_index') }}">Courriers actifs</a>
                {% else %}
                    <a class="button secondary" href="{{ path('app_courrier_index', {pendingDeletion: 1}) }}">Suppressions en attente ({{ pendingDeletionCount }})</a>
                {% endif %}
            {% endif %}
        </div>
    </div>

    <form class="form-panel" method="get" action="{{ path('app_courrier_index') }}" style="margin-bottom: 16px;">
        <div class="filters">
            {% if filters.destinataire|default('') %}
                <input type="hidden" name="destinataire" value="{{ filters.destinataire }}">
            {% endif %}
            <div>
                <label for="q">Mots-cles</label>
                <input id="q" name="q" value="{{ filters.q|default('') }}">
            </div>
            <div>
                <label for="sender">Interlocuteur</label>
                <input id="sender" name="sender" value="{{ filters.sender|default('') }}">
            </div>
            <div>
                <label for="status">Statut</label>
                <select id="status" name="status">
                    <option value="">Tous</option>
                    {% for label, value in statuses %}
                        <option value="{{ value }}" {{ filters.status|default('') == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="direction">Nature</label>
                <select id="direction" name="direction">
                    <option value="">Tous</option>
                    {% for label, value in directions %}
                        <option value="{{ value }}" {{ filters.direction|default('') == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="dateFrom">Du</label>
                <input type="date" id="dateFrom" name="dateFrom" value="{{ filters.dateFrom|default('') }}">
            </div>
            <div>
                <label for="dateTo">Au</label>
                <input type="date" id="dateTo" name="dateTo" value="{{ filters.dateTo|default('') }}">
            </div>
            <div>
                <label for="assignedTo">Imputer à</label>
                <select id="assignedTo" name="assignedTo">
                    <option value="">Tous</option>
                    {% for user in users %}
                        <option value="{{ user.id }}" {{ filters.assignedTo|default('') == user.id ? 'selected' : '' }}>{{ user.fullName }}</option>
                    {% endfor %}
                </select>
            </div>
            <div style="align-self: end;" class="actions">
                <button type="submit">Rechercher</button>
                <a class="button secondary" href="{{ path('app_courrier_index') }}">Reinitialiser</a>
            </div>
        </div>
    </form>

    {% if selectedDestinataire %}
        <div class="form-panel" style="margin-bottom: 16px;">
            <div class="topbar" style="margin-bottom: 0;">
                <div>
                    <strong>Filtre destinataire actif</strong>
                    <p>Courriers lies a {{ selectedDestinataire.name }} comme emetteur ou destinataire.</p>
                </div>
                <a class="button secondary" href="{{ path('app_courrier_index') }}">Retirer le filtre</a>
            </div>
        </div>
    {% endif %}

    {% if isPendingDeletionView %}
        <div class="form-panel" style="margin-bottom: 16px;">
            <strong>Demandes de suppression en attente</strong>
            <p>Ces courriers sont masques aux autres utilisateurs jusqu a l approbation ou au refus par un administrateur.</p>
        </div>
    {% endif %}

    <div class="table-wrap is-colorful">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Référence</th>
                    <th>Nature</th>
                    <th>Objet</th>
                    <th>Interlocuteur</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for courrier in courriers %}
                <tr>
                    <td>{{ courrier.mailDate|date('d/m/Y') }}</td>
                    <td>
                        {{ courrier.reference }}
                        {% if courrier.deletionPending %}
                            <span class="badge pending-deletion">Suppression en attente</span>
                        {% endif %}
                    </td>
                    <td>{{ directionLabels[courrier.direction]|default(courrier.directionLabel) }}</td>
                    <td><a href="{{ path('app_courrier_show', {id: courrier.id}) }}"><strong>{{ courrier.subject }}</strong></a></td>
                    <td>{{ courrier.interlocuteurLabel }}</td>
                    <td><span class="badge {{ courrier.status }}">{{ statusLabels[courrier.status]|default(courrier.statusLabel) }}</span></td>
                    <td>
                        <div class="row-actions">
                            <a class="button compact icon-only action-view" href="{{ path('app_courrier_show', {id: courrier.id}) }}" title="Afficher" aria-label="Afficher le courrier {{ courrier.reference }}">
                                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </a>
                            {% if is_granted('ROLE_COURRIER_EDIT') and not courrier.deletionPending %}
                                <a class="button compact icon-only action-edit" href="{{ path('app_courrier_edit', {id: courrier.id}) }}" title="Modifier" aria-label="Modifier le courrier {{ courrier.reference }}">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M12 20h9"/>
                                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>
                                    </svg>
                                </a>
                            {% endif %}
                            {% if courrier.attachmentFilename %}
                                <a class="button compact icon-only action-file" href="{{ asset('uploads/courriers/' ~ courrier.attachmentFilename) }}" target="_blank" title="Ouvrir le fichier" aria-label="Ouvrir le fichier joint du courrier {{ courrier.reference }}">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                        <path d="M14 2v6h6"/>
                                        <path d="M9 15h6"/>
                                        <path d="M9 18h4"/>
                                    </svg>
                                </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="muted">Aucun resultat.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
