{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
    <div class="topbar">
        <div>
            <h1>Tableau de bord</h1>
            <p>Vue d'ensemble des courriers recus, envoyes et a traiter.</p>
        </div>
        {% if is_granted('ROLE_COURRIER_EDIT') %}
            <div class="actions">
                <a class="button" href="{{ path('app_courrier_new') }}">Nouveau courrier</a>
            </div>
        {% endif %}
    </div>

    <form class="form-panel" method="get" action="{{ path('app_dashboard') }}" style="margin-bottom: 16px;">
        <div class="filters">
            <div>
                <label for="dateFrom">Date de debut</label>
                <input type="date" id="dateFrom" name="dateFrom" value="{{ filters.dateFrom|default('') }}">
            </div>
            <div>
                <label for="dateTo">Date de fin</label>
                <input type="date" id="dateTo" name="dateTo" value="{{ filters.dateTo|default('') }}">
            </div>
            <div style="align-self: end;" class="actions">
                {% if filters.status|default('') %}
                    <input type="hidden" name="status" value="{{ filters.status }}">
                {% endif %}
                {% if filters.direction|default('') %}
                    <input type="hidden" name="direction" value="{{ filters.direction }}">
                {% endif %}
                <button type="submit">Filtrer</button>
                <a class="button secondary" href="{{ path('app_dashboard') }}">Reinitialiser</a>
            </div>
        </div>
    </form>

    {% set periodParams = {
        dateFrom: filters.dateFrom|default(''),
        dateTo: filters.dateTo|default('')
    } %}
    {% set paginationParams = {
        dateFrom: filters.dateFrom|default(''),
        dateTo: filters.dateTo|default(''),
        status: filters.status|default(''),
        direction: filters.direction|default('')
    } %}

    <section class="grid stats">
        <a class="card stat stat--received {{ filters.direction|default('') == 'entrant' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({direction: 'entrant'})) }}">
            <span>{{ directionLabels.entrant|default('Arrivé') }}</span>
            <strong>{{ directionStats.entrant }}</strong>
        </a>
        <a class="card stat stat--sent {{ filters.direction|default('') == 'sortant' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({direction: 'sortant'})) }}">
            <span>{{ directionLabels.sortant|default('Départ') }}</span>
            <strong>{{ directionStats.sortant }}</strong>
        </a>
        <a class="card stat stat--internal {{ filters.direction|default('') == 'note_interne' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({direction: 'note_interne'})) }}">
            <span>{{ directionLabels.note_interne|default('Notes internes') }}</span>
            <strong>{{ directionStats.note_interne }}</strong>
        </a>
        <a class="card stat stat--progress {{ filters.status|default('') == 'en_cours' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({status: 'en_cours'})) }}">
            <span>{{ statusLabels.en_cours|default('En cours') }}</span>
            <strong>{{ statusStats.en_cours }}</strong>
        </a>
        <a class="card stat stat--done {{ filters.status|default('') == 'traite' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({status: 'traite'})) }}">
            <span>{{ statusLabels.traite|default('Traites') }}</span>
            <strong>{{ statusStats.traite }}</strong>
        </a>
        <a class="card stat stat--urgent {{ filters.status|default('') == 'urgent' ? 'active' : '' }}" href="{{ path('app_dashboard', periodParams|merge({status: 'urgent'})) }}">
            <span>{{ statusLabels.urgent|default('Urgents') }}</span>
            <strong>{{ statusStats.urgent }}</strong>
        </a>
    </section>

    <section class="grid two">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Objet</th>
                        <th>Interlocuteur</th>
                        <th>Statut</th>
                        <th>Impute a</th>
                    </tr>
                </thead>
                <tbody>
                {% for courrier in filteredCourriers %}
                    <tr>
                        <td>{{ courrier.mailDate|date('d/m/Y') }}</td>
                        <td><a href="{{ path('app_courrier_show', {id: courrier.id}) }}"><strong>{{ courrier.subject }}</strong></a></td>
                        <td>{{ courrier.interlocuteurLabel }}</td>
                        <td><span class="badge {{ courrier.status }}">{{ statusLabels[courrier.status]|default(courrier.statusLabel) }}</span></td>
                        <td>{{ courrier.assignedToLabel }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="muted">Aucun courrier pour ce filtre.</td></tr>
                {% endfor %}
                </tbody>
            </table>
            <div class="pagination">
                <span>
                    {{ pagination.total }} courrier{{ pagination.total > 1 ? 's' : '' }}
                    - page {{ pagination.page }} / {{ pagination.totalPages }}
                </span>
                <div class="actions">
                    {% if pagination.page > 1 %}
                        <a class="button secondary" href="{{ path('app_dashboard', paginationParams|merge({page: pagination.page - 1})) }}">Precedent</a>
                    {% endif %}
                    {% if pagination.page < pagination.totalPages %}
                        <a class="button secondary" href="{{ path('app_dashboard', paginationParams|merge({page: pagination.page + 1})) }}">Suivant</a>
                    {% endif %}
                </div>
            </div>
        </div>

        <aside class="card">
            <h2>Courriers urgents</h2>
            <div class="grid">
                {% for courrier in urgentCourriers|slice(0, 6) %}
                    <a href="{{ path('app_courrier_show', {id: courrier.id}) }}">
                        <strong>{{ courrier.subject }}</strong><br>
                        <span class="muted">{{ courrier.interlocuteurLabel }} - {{ courrier.mailDate|date('d/m/Y') }}</span>
                    </a>
                {% else %}
                    <p>Aucun courrier urgent.</p>
                {% endfor %}
            </div>
        </aside>
    </section>
{% endblock %}
