<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Gestion Courrier{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            <style>
                :root {
                    color-scheme: light;
                    --bg: #f5f7fb;
                    --panel: #ffffff;
                    --panel-soft: #eef4f8;
                    --border: #d7e0e8;
                    --text: #17212b;
                    --muted: #607080;
                    --primary: #116c7a;
                    --primary-strong: #0a5661;
                    --accent: #b7442e;
                    --success: #26734d;
                    --warning: #a76500;
                    --shadow: 0 12px 30px rgba(15, 35, 52, 0.08);
                }

                * { box-sizing: border-box; }

                body {
                    margin: 0;
                    min-height: 100vh;
                    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
                    background: var(--bg);
                    color: var(--text);
                    letter-spacing: 0;
                }

                a { color: inherit; text-decoration: none; }

                .app-shell {
                    display: grid;
                    grid-template-columns: 250px 1fr;
                    min-height: 100vh;
                }

                .app-shell--guest {
                    display: block;
                    min-height: 100vh;
                }

                .app-shell--guest .main {
                    min-height: 100vh;
                    padding: 0;
                }

                .sidebar {
                    background: #102531;
                    color: #f7fbfd;
                    display: flex;
                    flex-direction: column;
                    padding: 24px 16px;
                }

                .brand {
                    align-items: center;
                    display: flex;
                    gap: 10px;
                    font-size: 22px;
                    font-weight: 800;
                    letter-spacing: 0;
                    margin-bottom: 26px;
                    padding: 0 8px;
                }

                .brand__mark {
                    align-items: center;
                    background: #d8f0f2;
                    border-radius: 8px;
                    color: #0b4f59;
                    display: inline-flex;
                    flex: 0 0 34px;
                    height: 34px;
                    justify-content: center;
                    width: 34px;
                }

                .nav { display: grid; gap: 6px; }

                .nav a {
                    align-items: center;
                    border-radius: 8px;
                    display: flex;
                    gap: 10px;
                    color: #dbe8ee;
                    min-height: 44px;
                    padding: 10px 12px;
                    font-weight: 650;
                    transition: background 160ms ease, color 160ms ease, transform 160ms ease;
                }

                .nav a:hover, .nav a.active {
                    background: rgba(255, 255, 255, 0.12);
                    color: #fff;
                    transform: translateX(2px);
                }

                .nav a.active {
                    background: #e8f6f5;
                    color: #0d4f59;
                    box-shadow: 0 10px 22px rgba(2, 14, 20, 0.18);
                }

                .nav__icon {
                    align-items: center;
                    background: rgba(255, 255, 255, 0.1);
                    border-radius: 8px;
                    display: inline-flex;
                    flex: 0 0 30px;
                    height: 30px;
                    justify-content: center;
                    width: 30px;
                }

                .nav a.active .nav__icon {
                    background: rgba(17, 108, 122, 0.12);
                }

                .nav__icon svg, .brand__mark svg {
                    display: block;
                    height: 18px;
                    stroke: currentColor;
                    width: 18px;
                }

                .user-box {
                    border-top: 1px solid rgba(255, 255, 255, 0.16);
                    margin-top: auto;
                    padding-top: 18px;
                    color: #c9d8df;
                    font-size: 14px;
                }

                .main { padding: 28px; min-width: 0; }
                .topbar { display: flex; align-items: flex-start; justify-content: space-between; gap: 18px; margin-bottom: 22px; }
                .page-band {
                    background: #e9f6f4;
                    border: 1px solid #c8e5df;
                    border-left: 6px solid var(--primary);
                    border-radius: 8px;
                    box-shadow: var(--shadow);
                    padding: 18px;
                }
                .page-band h1 { color: #0e4f5b; }
                .page-band p { color: #425e68; }
                h1 { margin: 0; font-size: 30px; line-height: 1.15; }
                h2 { margin: 0 0 14px; font-size: 20px; }
                p { margin: 0; color: var(--muted); }

                .actions { display: flex; gap: 10px; flex-wrap: wrap; }
                .button, button {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 8px;
                    min-height: 40px;
                    border: 0;
                    border-radius: 8px;
                    background: var(--primary);
                    color: #fff;
                    cursor: pointer;
                    font: inherit;
                    font-weight: 750;
                    padding: 10px 14px;
                }

                .button.secondary, button.secondary { background: #dfe8ee; color: #1b2a33; }
                .button.danger, button.danger { background: var(--accent); }
                .button.action-view { background: #145a66; color: #fff; }
                .button.action-edit { background: #e4f0f6; color: #1c5570; }
                .button.action-file { background: #f3e6bd; color: #694d08; }
                .button.compact, button.compact {
                    font-size: 13px;
                    min-height: 32px;
                    padding: 7px 10px;
                }
                .button.icon-only {
                    min-width: 34px;
                    padding: 7px;
                }
                .button svg {
                    height: 17px;
                    stroke: currentColor;
                    width: 17px;
                }
                .button:hover, button:hover { background: var(--primary-strong); }
                .button.action-edit:hover { background: #cfe3ed; color: #123f52; }
                .button.action-file:hover { background: #ead690; color: #4f3b07; }

                .grid { display: grid; gap: 16px; }
                .grid.stats { grid-template-columns: repeat(6, minmax(130px, 1fr)); margin-bottom: 18px; }
                .grid.two { grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr); }

                .card, .table-wrap, .form-panel {
                    background: var(--panel);
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    box-shadow: var(--shadow);
                }

                .card { padding: 18px; }
                .stat {
                    border-left: 5px solid var(--primary);
                    transition: border-color 160ms ease, transform 160ms ease;
                }
                .stat:hover, .stat.active { transform: translateY(-1px); }
                .stat--received { border-left-color: #2f6f9f; background: #f1f7fb; }
                .stat--sent { border-left-color: #7a5b15; background: #fff8e8; }
                .stat--internal { border-left-color: #6b5aa6; background: #f5f2fb; }
                .stat--progress { border-left-color: var(--warning); background: #fff7df; }
                .stat--done { border-left-color: var(--success); background: #edf8f1; }
                .stat--urgent { border-left-color: var(--accent); background: #fff0ea; }
                .stat.active { box-shadow: 0 0 0 2px rgba(17, 108, 122, 0.18), var(--shadow); }
                .stat strong { display: block; font-size: 30px; line-height: 1; margin-top: 10px; }
                .stat span { color: var(--muted); font-weight: 700; }

                .table-wrap { overflow: auto; }
                .table-wrap.is-colorful {
                    border-color: #c8e0e7;
                    box-shadow: 0 16px 36px rgba(13, 67, 78, 0.11);
                }
                table { border-collapse: collapse; width: 100%; min-width: 780px; }
                th, td { border-bottom: 1px solid var(--border); padding: 13px 14px; text-align: left; vertical-align: top; }
                th { color: var(--muted); font-size: 13px; text-transform: uppercase; }
                tr:last-child td { border-bottom: 0; }
                .table-wrap.is-colorful thead th {
                    background: #115f6c;
                    border-bottom: 0;
                    color: #f4fbfc;
                }
                .table-wrap.is-colorful tbody tr:nth-child(even) { background: #f7fbfb; }
                .table-wrap.is-colorful tbody tr:hover { background: #edf8f6; }
                .table-wrap.is-colorful td:first-child { border-left: 4px solid #a7d6cd; }
                .pagination {
                    align-items: center;
                    background: #fff;
                    border-top: 1px solid var(--border);
                    display: flex;
                    justify-content: space-between;
                    gap: 12px;
                    min-width: 780px;
                    padding: 12px 14px;
                }

                .pagination span { color: var(--muted); font-weight: 700; }
                .row-actions {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 7px;
                    min-width: 210px;
                }

                .badge {
                    display: inline-flex;
                    align-items: center;
                    border-radius: 999px;
                    font-size: 12px;
                    font-weight: 800;
                    padding: 5px 9px;
                    background: var(--panel-soft);
                    color: #25404c;
                    white-space: nowrap;
                }

                .badge.urgent { background: #ffe8df; color: #9d2d14; }
                .badge.traite { background: #dff3e8; color: var(--success); }
                .badge.en_cours { background: #fff2cf; color: var(--warning); }

                .filters, .form-grid {
                    display: grid;
                    grid-template-columns: repeat(4, minmax(160px, 1fr));
                    gap: 12px;
                }

                .form-panel { padding: 18px; }
                .professional-form {
                    display: grid;
                    gap: 18px;
                }

                .form-section {
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    background: #fbfdfe;
                    padding: 16px;
                }

                .form-section__header {
                    border-bottom: 1px solid var(--border);
                    margin-bottom: 14px;
                    padding-bottom: 10px;
                }

                .form-section__header h2 { margin: 0; }
                .form-section__header p { margin-top: 4px; }
                .is-hidden { display: none !important; }
                label { color: #293a46; display: block; font-weight: 750; margin-bottom: 7px; }
                input, select, textarea {
                    width: 100%;
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    color: var(--text);
                    font: inherit;
                    min-height: 42px;
                    padding: 10px 11px;
                    background: #fff;
                }

                textarea { resize: vertical; }
                input[type="checkbox"] {
                    accent-color: var(--primary);
                    min-height: 0;
                    width: auto;
                }
                .sr-only-select {
                    position: absolute;
                    width: 1px;
                    height: 1px;
                    overflow: hidden;
                    clip: rect(0 0 0 0);
                    white-space: nowrap;
                }

                .autocomplete-multi {
                    position: relative;
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    background: #fff;
                    min-height: 42px;
                    padding: 6px;
                }

                .autocomplete-multi:focus-within {
                    border-color: var(--primary);
                    box-shadow: 0 0 0 3px rgba(17, 108, 122, 0.14);
                }

                .autocomplete-multi__chips {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 6px;
                    margin-bottom: 6px;
                }

                .autocomplete-multi__chip {
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                    border-radius: 999px;
                    background: var(--panel-soft);
                    color: #25404c;
                    font-weight: 750;
                    padding: 5px 8px;
                }

                .autocomplete-multi__chip button {
                    min-height: 0;
                    width: 20px;
                    height: 20px;
                    border-radius: 999px;
                    padding: 0;
                    background: #cfdbe3;
                    color: #1f313c;
                    line-height: 1;
                }

                .autocomplete-multi__input {
                    border: 0;
                    min-height: 30px;
                    padding: 4px;
                }

                .autocomplete-multi__input:focus { outline: 0; }

                .autocomplete-multi__results {
                    position: absolute;
                    z-index: 20;
                    top: calc(100% + 4px);
                    left: 0;
                    right: 0;
                    display: none;
                    max-height: 220px;
                    overflow: auto;
                    border: 1px solid var(--border);
                    border-radius: 8px;
                    background: #fff;
                    box-shadow: var(--shadow);
                    padding: 6px;
                }

                .autocomplete-multi__results.is-open { display: grid; gap: 4px; }

                .autocomplete-multi__option {
                    border: 0;
                    border-radius: 6px;
                    background: transparent;
                    color: var(--text);
                    justify-content: flex-start;
                    min-height: 34px;
                    padding: 7px 9px;
                    text-align: left;
                    width: 100%;
                }

                .autocomplete-multi__option:hover { background: var(--panel-soft); color: var(--text); }
                .full { grid-column: 1 / -1; }
                .form-actions { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
                .form-errors, .flash.error { color: #9d2d14; }
                .flash {
                    border-radius: 8px;
                    background: #e8f4ef;
                    color: var(--success);
                    font-weight: 700;
                    margin-bottom: 14px;
                    padding: 12px 14px;
                }

                .detail-list { display: grid; gap: 12px; }
                .detail-list div { border-bottom: 1px solid var(--border); padding-bottom: 12px; }
                .detail-list dt { color: var(--muted); font-weight: 800; margin-bottom: 4px; }
                .detail-list dd { margin: 0; }
                .login-page {
                    align-items: center;
                    background:
                        linear-gradient(135deg, rgba(16, 37, 49, 0.94), rgba(17, 108, 122, 0.82)),
                        linear-gradient(0deg, #102531, #102531);
                    display: grid;
                    min-height: 100vh;
                    padding: 34px;
                }
                .login-shell {
                    display: grid;
                    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 460px);
                    gap: 34px;
                    margin: 0 auto;
                    max-width: 1080px;
                    width: 100%;
                }
                .login-intro {
                    color: #f7fbfd;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    min-height: 520px;
                }
                .login-brand {
                    align-items: center;
                    display: flex;
                    gap: 12px;
                    font-size: 24px;
                    font-weight: 850;
                    margin-bottom: 42px;
                }
                .login-brand__mark {
                    align-items: center;
                    background: #e7f6f5;
                    border-radius: 8px;
                    color: #0a5661;
                    display: inline-flex;
                    height: 42px;
                    justify-content: center;
                    width: 42px;
                }
                .login-brand__mark svg, .login-feature svg {
                    height: 21px;
                    stroke: currentColor;
                    width: 21px;
                }
                .login-intro h1 {
                    color: #fff;
                    font-size: 42px;
                    max-width: 620px;
                }
                .login-intro p {
                    color: #d9e9ee;
                    font-size: 16px;
                    line-height: 1.7;
                    margin-top: 16px;
                    max-width: 560px;
                }
                .login-features {
                    display: grid;
                    gap: 12px;
                    margin-top: 34px;
                    max-width: 520px;
                }
                .login-feature {
                    align-items: center;
                    background: rgba(255, 255, 255, 0.1);
                    border: 1px solid rgba(255, 255, 255, 0.16);
                    border-radius: 8px;
                    color: #eef8fa;
                    display: flex;
                    gap: 12px;
                    padding: 12px 14px;
                }
                .login-card {
                    align-self: center;
                    background: #fff;
                    border: 1px solid rgba(255, 255, 255, 0.5);
                    border-radius: 8px;
                    box-shadow: 0 28px 70px rgba(5, 19, 28, 0.32);
                    padding: 30px;
                }
                .login-card__head {
                    border-bottom: 1px solid var(--border);
                    margin-bottom: 22px;
                    padding-bottom: 18px;
                }
                .login-card h2 {
                    color: #102531;
                    font-size: 28px;
                    margin-bottom: 7px;
                }
                .login-card p { line-height: 1.55; }
                .login-form { display: grid; gap: 15px; }
                .login-field { display: grid; gap: 7px; }
                .login-input { position: relative; }
                .login-input input { padding-left: 42px; }
                .login-input svg {
                    color: #607080;
                    height: 18px;
                    left: 13px;
                    pointer-events: none;
                    position: absolute;
                    stroke: currentColor;
                    top: 50%;
                    transform: translateY(-50%);
                    width: 18px;
                }
                .login-submit {
                    margin-top: 6px;
                    width: 100%;
                }
                .login-note {
                    background: #f3f8fa;
                    border: 1px solid #dbe9ee;
                    border-radius: 8px;
                    color: #48616e;
                    font-size: 13px;
                    line-height: 1.5;
                    margin-top: 18px;
                    padding: 12px;
                }
                .history-list { display: grid; gap: 12px; margin-top: 14px; }
                .history-item {
                    border-left: 4px solid var(--primary);
                    background: #f7fbfb;
                    border-radius: 8px;
                    padding: 12px;
                }
                .history-item.created { border-left-color: var(--success); }
                .history-item.assigned { border-left-color: #2f6f9f; }
                .history-item.status_changed { border-left-color: var(--warning); }
                .history-item.response_added { border-left-color: #6b5aa6; }
                .history-item__head {
                    display: flex;
                    justify-content: space-between;
                    gap: 10px;
                    margin-bottom: 6px;
                }
                .history-item__head strong { color: #17212b; }
                .history-item time { color: var(--muted); font-size: 12px; font-weight: 800; white-space: nowrap; }
                .history-item p { color: #314653; font-size: 14px; margin-top: 5px; }
                .history-item pre {
                    color: #526572;
                    font: inherit;
                    font-size: 13px;
                    margin: 8px 0 0;
                    white-space: pre-wrap;
                }
                .muted { color: var(--muted); }

                @media (max-width: 920px) {
                    .app-shell { grid-template-columns: 1fr; }
                    .sidebar { position: static; }
                    .main { padding: 18px; }
                    .app-shell--guest .main { padding: 0; }
                    .grid.stats, .grid.two, .filters, .form-grid { grid-template-columns: 1fr; }
                    .topbar { flex-direction: column; }
                    .login-page { padding: 20px; }
                    .login-shell { grid-template-columns: 1fr; gap: 20px; }
                    .login-intro { min-height: auto; }
                    .login-intro h1 { font-size: 32px; }
                    .login-features { display: none; }
                    .login-card { padding: 22px; }
                }
            </style>
        {% endblock %}

        {% block javascripts %}
            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    document.querySelectorAll('[data-autocomplete-select]').forEach((select) => {
                        if (select.dataset.autocompleteReady === 'true') {
                            return;
                        }

                        select.dataset.autocompleteReady = 'true';

                        const wrapper = document.createElement('div');
                        wrapper.className = 'autocomplete-multi';

                        const chips = document.createElement('div');
                        chips.className = 'autocomplete-multi__chips';

                        const input = document.createElement('input');
                        input.type = 'text';
                        input.className = 'autocomplete-multi__input';
                        input.placeholder = select.dataset.placeholder || 'Rechercher';
                        input.autocomplete = 'off';

                        const results = document.createElement('div');
                        results.className = 'autocomplete-multi__results';

                        wrapper.append(chips, input, results);
                        select.insertAdjacentElement('afterend', wrapper);

                        const options = Array.from(select.options).filter((option) => option.value);
                        const normalize = (value) => value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

                        const selectedOptions = () => options.filter((option) => option.selected);

                        const sync = () => {
                            chips.innerHTML = '';

                            selectedOptions().forEach((option) => {
                                const chip = document.createElement('span');
                                chip.className = 'autocomplete-multi__chip';
                                chip.textContent = option.textContent;

                                const remove = document.createElement('button');
                                remove.type = 'button';
                                remove.setAttribute('aria-label', 'Retirer ' + option.textContent);
                                remove.textContent = 'x';
                                remove.addEventListener('click', () => {
                                    option.selected = false;
                                    sync();
                                    renderResults();
                                    input.focus();
                                });

                                chip.append(remove);
                                chips.append(chip);
                            });
                        };

                        const renderResults = () => {
                            const query = normalize(input.value.trim());
                            if (!query) {
                                results.innerHTML = '';
                                results.classList.remove('is-open');

                                return;
                            }

                            const matches = options
                                .filter((option) => !option.selected)
                                .filter((option) => normalize(option.textContent).includes(query))
                                .slice(0, 8);

                            results.innerHTML = '';
                            results.classList.toggle('is-open', matches.length > 0);

                            matches.forEach((option) => {
                                const button = document.createElement('button');
                                button.type = 'button';
                                button.className = 'autocomplete-multi__option';
                                button.textContent = option.textContent;
                                button.addEventListener('mousedown', (event) => event.preventDefault());
                                button.addEventListener('click', () => {
                                    option.selected = true;
                                    input.value = '';
                                    sync();
                                    renderResults();
                                    input.focus();
                                });
                                results.append(button);
                            });
                        };

                        input.addEventListener('input', renderResults);
                        input.addEventListener('focus', renderResults);
                        input.addEventListener('keydown', (event) => {
                            if (event.key === 'Escape') {
                                results.classList.remove('is-open');
                            }
                        });
                        document.addEventListener('click', (event) => {
                            if (!wrapper.contains(event.target)) {
                                results.classList.remove('is-open');
                            }
                        });

                        sync();
                    });

                    document.querySelectorAll('[data-courrier-form]').forEach((form) => {
                        const direction = form.querySelector('[data-direction-field]');
                        const senderGroup = form.querySelector('[data-visible-for="entrant"]');
                        const recipientGroup = form.querySelector('[data-visible-for="sortant"]');
                        const updateContactFields = () => {
                            const value = direction ? direction.value : '';
                            const showSender = value === 'entrant';
                            const showRecipients = value === 'sortant' || value === 'note_interne';

                            if (senderGroup) {
                                senderGroup.classList.toggle('is-hidden', !showSender);
                                senderGroup.querySelectorAll('select, input, textarea').forEach((field) => {
                                    field.disabled = !showSender;
                                });
                            }

                            if (recipientGroup) {
                                recipientGroup.classList.toggle('is-hidden', !showRecipients);
                                recipientGroup.querySelectorAll('select, input, textarea').forEach((field) => {
                                    field.disabled = !showRecipients;
                                });
                            }
                        };

                        if (direction) {
                            direction.addEventListener('change', updateContactFields);
                            updateContactFields();
                        }
                    });
                });
            </script>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <div class="app-shell {{ app.user ? '' : 'app-shell--guest' }}">
            {% if app.user %}
                {% set currentRoute = app.request.attributes.get('_route') %}
                <aside class="sidebar">
                    <a class="brand" href="{{ path('app_dashboard') }}">
                        <span class="brand__mark" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5z"/>
                                <path d="m8 9 4 3 4-3"/>
                                <path d="M8 15h8"/>
                            </svg>
                        </span>
                        <span>Gestion Courrier</span>
                    </a>
                    <nav class="nav">
                        <a class="{{ currentRoute == 'app_dashboard' ? 'active' : '' }}" href="{{ path('app_dashboard') }}">
                            <span class="nav__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="7" height="7"/>
                                    <rect x="14" y="3" width="7" height="7"/>
                                    <rect x="14" y="14" width="7" height="7"/>
                                    <rect x="3" y="14" width="7" height="7"/>
                                </svg>
                            </span>
                            <span>Tableau de bord</span>
                        </a>
                        <a class="{{ currentRoute in ['app_courrier_index', 'app_courrier_show', 'app_courrier_edit'] ? 'active' : '' }}" href="{{ path('app_courrier_index') }}">
                            <span class="nav__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="11" cy="11" r="7"/>
                                    <path d="m16.5 16.5 4 4"/>
                                    <path d="M8 11h6"/>
                                </svg>
                            </span>
                            <span>Trouver un courrier</span>
                        </a>
                        {% if is_granted('ROLE_SECRETARIAT') %}
                            <a class="{{ currentRoute == 'app_courrier_new' ? 'active' : '' }}" href="{{ path('app_courrier_new') }}">
                                <span class="nav__icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 3v5a2 2 0 0 0 2 2h5"/>
                                        <path d="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l7 7v9a2 2 0 0 1-2 2z"/>
                                        <path d="M12 12v6"/>
                                        <path d="M9 15h6"/>
                                    </svg>
                                </span>
                                <span>Enregistrer nouveau</span>
                            </a>
                            <a class="{{ currentRoute starts with 'app_destinataire_' ? 'active' : '' }}" href="{{ path('app_destinataire_index') }}">
                                <span class="nav__icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                                        <circle cx="9" cy="7" r="4"/>
                                        <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                    </svg>
                                </span>
                                <span>Destinataires</span>
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="{{ currentRoute starts with 'app_list_option_' ? 'active' : '' }}" href="{{ path('app_list_option_index') }}">
                                <span class="nav__icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                        <path d="M19.4 15a1.8 1.8 0 0 0 .36 1.98l.05.05a2.1 2.1 0 0 1-2.97 2.97l-.05-.05a1.8 1.8 0 0 0-1.98-.36 1.8 1.8 0 0 0-1.09 1.65V21a2.1 2.1 0 0 1-4.2 0v-.07a1.8 1.8 0 0 0-1.09-1.65 1.8 1.8 0 0 0-1.98.36l-.05.05a2.1 2.1 0 0 1-2.97-2.97l.05-.05A1.8 1.8 0 0 0 4.6 15a1.8 1.8 0 0 0-1.65-1.09H2.9a2.1 2.1 0 0 1 0-4.2h.07A1.8 1.8 0 0 0 4.6 8a1.8 1.8 0 0 0-.36-1.98l-.05-.05A2.1 2.1 0 0 1 7.16 3l.05.05A1.8 1.8 0 0 0 9.2 3.4 1.8 1.8 0 0 0 10.29 1.75V1.7a2.1 2.1 0 0 1 4.2 0v.07A1.8 1.8 0 0 0 15.58 3.4a1.8 1.8 0 0 0 1.98-.36l.05-.05a2.1 2.1 0 0 1 2.97 2.97l-.05.05A1.8 1.8 0 0 0 19.4 8a1.8 1.8 0 0 0 1.65 1.09h.05a2.1 2.1 0 0 1 0 4.2h-.07A1.8 1.8 0 0 0 19.4 15z"/>
                                    </svg>
                                </span>
                                <span>Paramètres</span>
                            </a>
                            <a class="{{ currentRoute starts with 'app_user_' ? 'active' : '' }}" href="{{ path('app_user_index') }}">
                                <span class="nav__icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                        <circle cx="8.5" cy="7" r="4"/>
                                        <path d="M20 8v6"/>
                                        <path d="M23 11h-6"/>
                                    </svg>
                                </span>
                                <span>Utilisateurs</span>
                            </a>
                        {% endif %}
                    </nav>
                    <div class="user-box">
                        <strong>{{ app.user.fullName }}</strong><br>
                        <span>{{ app.user.email }}</span>
                        <div style="margin-top: 14px;">
                            <a class="button secondary" href="{{ path('app_logout') }}">Deconnexion</a>
                        </div>
                    </div>
                </aside>
            {% endif %}
            <main class="main">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash {{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
                {% block body %}{% endblock %}
            </main>
        </div>
    </body>
</html>
