{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "prod",
    "APP_DEBUG": "0",
    "APP_SHARE_DIR": "/tmp/gestioncourrier-share",
    "APP_VAR_DIR": "/tmp/gestioncourrier/var",
    "DATABASE_URL": "sqlite:////tmp/gestioncourrier/data_prod.db",
    "DEFAULT_URI": "https://gestioncourrier-sandy.vercel.app"
  }
}
